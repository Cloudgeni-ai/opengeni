# Copy to .env and fill in. Never commit .env.
#
# Full stack: temporal server start-dev, alembic upgrade, worker + API with these set.

INFRA_AGENT_ENABLE_TEMPORAL_DISPATCH=true
INFRA_AGENT_OPENAI_PROVIDER=azure
INFRA_AGENT_AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
INFRA_AGENT_AZURE_OPENAI_API_KEY=your-key
# Optional with base_url v1 style: omit api version
INFRA_AGENT_OPENAI_MODEL=gpt-5.5
INFRA_AGENT_SANDBOX_BACKEND=modal

# Sandbox backend:
# - modal: hosted Modal sandbox
# - docker: local Docker container sandbox
# - none: disable sandbox dispatch
#
# Docker requires Docker Engine and the openai-agents docker extra.
# The image must contain git for repository resources to mount through GitRepo.
# INFRA_AGENT_SANDBOX_BACKEND=docker
INFRA_AGENT_DOCKER_IMAGE=infra-agents-sandbox:local
# INFRA_AGENT_DOCKER_EXPOSED_PORTS=

INFRA_AGENT_MODAL_APP_NAME=infra-agents-sandbox
INFRA_AGENT_MODAL_SANDBOX_CREATE_TIMEOUT_SECONDS=600
# Modal builds from docker/sandbox.Dockerfile by default, so it uses the same capability image
# as Docker without requiring a registry push. Override these only if needed:
# INFRA_AGENT_MODAL_DOCKERFILE=docker/sandbox.Dockerfile
# INFRA_AGENT_MODAL_DOCKER_CONTEXT_DIR=.
#
# You can also use a prebuilt registry image instead:
#   docker build -f docker/sandbox.Dockerfile -t ghcr.io/YOUR_ORG/infra-agents-sandbox:dev .
#   docker push ghcr.io/YOUR_ORG/infra-agents-sandbox:dev
#   INFRA_AGENT_DOCKER_IMAGE=ghcr.io/YOUR_ORG/infra-agents-sandbox:dev
#   INFRA_AGENT_MODAL_IMAGE_REF=ghcr.io/YOUR_ORG/infra-agents-sandbox:dev
# INFRA_AGENT_MODAL_IMAGE_REF=ghcr.io/YOUR_ORG/infra-agents-sandbox:dev

# Sandbox credential pass-through. Profiles choose which process env var names may cross into
# the sandbox at run dispatch time. Values must be present in the API/dispatcher process env.
# Built-in profiles:
# - azure: ARM_* for Terraform azurerm and AZURE_* service-principal vars for Azure tooling
# - github: GH_TOKEN / GITHUB_TOKEN for gh, git, pushes, and PR creation,
#           plus GIT_AUTHOR_* / GIT_COMMITTER_* when set
# - none: pass no profiled variables
INFRA_AGENT_SANDBOX_ENV_PROFILES=azure,github
# Add project-specific names without replacing the profile defaults.
# INFRA_AGENT_SANDBOX_ENV_EXTRA_VARS=TF_VAR_region,CUSTOM_PROVIDER_TOKEN
# Legacy explicit override, if you need total control. When set, it replaces profiles + extras.
# INFRA_AGENT_SANDBOX_ENV_VARS=GH_TOKEN,ARM_SUBSCRIPTION_ID

# Example sandbox credentials. Prefer short-lived tokens/secrets. These are intentionally not
# INFRA_AGENT_ settings; they are the exact names Terraform, Azure tooling, and gh expect.
# GitHub App-selected repositories mint their own short-lived token at dispatch time, so GH_TOKEN
# is mainly for manual URL repos or non-app GitHub access.
# ARM_CLIENT_ID=...
# ARM_CLIENT_SECRET=...
# ARM_TENANT_ID=...
# ARM_SUBSCRIPTION_ID=...
# These mirror the ARM_* values for Azure CLI/SDK tools. The sandbox helper
# `infra-agent-azure-login` also falls back to ARM_* when AZURE_* is omitted.
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_TENANT_ID=...
# AZURE_SUBSCRIPTION_ID=...
# GH_TOKEN=...
# Optional raw git identity overrides. If unset, the dispatcher uses the configured GitHub
# App bot identity when available, otherwise a simple local fallback.
# GIT_AUTHOR_NAME=
# GIT_AUTHOR_EMAIL=
# GIT_COMMITTER_NAME=
# GIT_COMMITTER_EMAIL=

# Optional INFRA_AGENT_-scoped git identity overrides. These do not require adding raw
# GIT_* names to the sandbox env profile.
# INFRA_AGENT_GIT_AUTHOR_NAME=
# INFRA_AGENT_GIT_AUTHOR_EMAIL=
# INFRA_AGENT_GIT_COMMITTER_NAME=
# INFRA_AGENT_GIT_COMMITTER_EMAIL=

# GitHub App manifest flow. Localhost works for creating credentials because webhooks are
# omitted from the manifest unless the base URL is public HTTPS. Set base URL when the API is
# behind a public domain or tunnel and you want webhook subscriptions in the generated app.
# INFRA_AGENT_GITHUB_APP_MANIFEST_BASE_URL=https://YOUR_DOMAIN
# INFRA_AGENT_GITHUB_APP_MANIFEST_STATE_SECRET=change-me
#
# Filled after GitHub redirects back from the manifest flow.
# INFRA_AGENT_GITHUB_APP_ID=
# INFRA_AGENT_GITHUB_CLIENT_ID=
# INFRA_AGENT_GITHUB_CLIENT_SECRET=
# INFRA_AGENT_GITHUB_APP_SLUG=
# INFRA_AGENT_GITHUB_WEBHOOK_SECRET=
# INFRA_AGENT_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Modal: worker sets MODAL_TOKEN_ID, MODAL_TOKEN_SECRET (etc.) for the official `modal` client
# (same names Modal reads; env wins over ~/.modal.toml). Use INFRA_AGENT_ prefix with .env, or
# set MODAL_* in the shell instead. If both are omitted, use: modal token set ...
INFRA_AGENT_MODAL_TOKEN_ID=ak-...
INFRA_AGENT_MODAL_TOKEN_SECRET=as-...
# INFRA_AGENT_MODAL_PROFILE=default
# INFRA_AGENT_MODAL_CONFIG_PATH=/path/to/.modal.toml
