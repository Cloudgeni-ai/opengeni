# Copy to .env and fill in. Never commit .env.
#
# Full stack: temporal server start-dev, alembic upgrade, worker + API with these set.

CLOUD_AGENT_ENABLE_TEMPORAL_DISPATCH=true
CLOUD_AGENT_OPENAI_PROVIDER=azure
CLOUD_AGENT_AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
CLOUD_AGENT_AZURE_OPENAI_API_KEY=your-key
# Optional with base_url v1 style: omit api version
CLOUD_AGENT_OPENAI_MODEL=gpt-5.4
CLOUD_AGENT_SANDBOX_BACKEND=modal
CLOUD_AGENT_MODAL_APP_NAME=infra-agents-sandbox

# Modal (used by the OpenAI Agents SDK sandbox client; official Modal Python API)
# Prefer env over ~/.modal.toml for CI and containers. Env wins over the file.
# See: modal/config.py in the `modal` package.
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...
# Optional: name of a profile in ~/.modal.toml; ignored if the two tokens are set
# in env (Modal uses the env credentials directly). Use when relying on file only:
# MODAL_PROFILE=default
# Optional: override TOML path
# MODAL_CONFIG_PATH=/path/to/.modal.toml
#
# Or once per machine: `uv run modal token set --token-id ... --token-secret ... --profile=...`
