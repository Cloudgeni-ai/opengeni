# Copy to .env and fill in. Never commit .env.

INFRA_AGENT_SERVICE_NAME=infra-agents
INFRA_AGENT_ENVIRONMENT=local
INFRA_AGENT_DATABASE_URL=postgres://infra_agents:infra_agents@127.0.0.1:5432/infra_agents
INFRA_AGENT_NATS_URL=nats://127.0.0.1:4222
INFRA_AGENT_TEMPORAL_HOST=127.0.0.1:7233
INFRA_AGENT_TEMPORAL_NAMESPACE=default
INFRA_AGENT_TEMPORAL_TASK_QUEUE=infra-agent-runs-ts
INFRA_AGENT_API_HOST=0.0.0.0
INFRA_AGENT_API_PORT=8000
# CORS origin allowlist regex. The API matches this as a full-string regex.
INFRA_AGENT_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# OpenAI provider.
INFRA_AGENT_OPENAI_PROVIDER=openai
INFRA_AGENT_OPENAI_MODEL=gpt-5.5
INFRA_AGENT_OPENAI_REASONING_EFFORT=high
INFRA_AGENT_OPENAI_ALLOWED_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini
INFRA_AGENT_OPENAI_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
INFRA_AGENT_OPENAI_API_KEY=your-key
# INFRA_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
# INFRA_AGENT_OPENAI_RESPONSES_TRANSPORT=websocket
# INFRA_AGENT_DISABLE_OPENAI_TRACING=true

# Azure OpenAI provider.
# INFRA_AGENT_OPENAI_PROVIDER=azure
# INFRA_AGENT_AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
# INFRA_AGENT_AZURE_OPENAI_API_KEY=your-key
# INFRA_AGENT_AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# INFRA_AGENT_AZURE_OPENAI_DEPLOYMENT=your-deployment
# INFRA_AGENT_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# INFRA_AGENT_AZURE_OPENAI_AD_TOKEN=...

# Sandbox backend: docker, modal, local, or none.
INFRA_AGENT_SANDBOX_BACKEND=docker
INFRA_AGENT_DOCKER_IMAGE=infra-agents-sandbox:local
# INFRA_AGENT_DOCKER_EXPOSED_PORTS=3000,8080

# Modal sandbox backend.
INFRA_AGENT_MODAL_APP_NAME=infra-agents-sandbox
INFRA_AGENT_MODAL_TIMEOUT_SECONDS=900
# INFRA_AGENT_MODAL_IMAGE_REF=ghcr.io/YOUR_ORG/infra-agents-sandbox:dev
# INFRA_AGENT_MODAL_TOKEN_ID=ak-...
# INFRA_AGENT_MODAL_TOKEN_SECRET=as-...
# INFRA_AGENT_MODAL_ENVIRONMENT=main

# Sandbox credential pass-through. Profiles copy known API/worker env vars into sandbox manifests.
# Supported profiles: azure, github, none. Setting INFRA_AGENT_SANDBOX_ENV_VARS replaces profiles entirely.
INFRA_AGENT_SANDBOX_ENV_PROFILES=azure,github
# Add extra env var names on top of the selected profiles.
# INFRA_AGENT_SANDBOX_ENV_EXTRA_VARS=TF_VAR_region,CUSTOM_PROVIDER_TOKEN
# Explicit override for all sandbox env var names.
# INFRA_AGENT_SANDBOX_ENV_VARS=GH_TOKEN,ARM_SUBSCRIPTION_ID

# Session-level MCP tool providers. Clients select these by id with `tools: [{ "kind": "mcp", "id": "docs" }]`.
# Built-in API MCP defaults to http://127.0.0.1:${INFRA_AGENT_API_PORT}/v1/mcp and exposes scheduled task tools.
# A built-in `docs` provider is also registered at /v1/mcp/docs unless overridden here.
# INFRA_AGENT_MCP_URL=http://127.0.0.1:8000/v1/mcp
# INFRA_AGENT_MCP_SERVERS='[{"id":"docs","name":"Document Search","url":"http://127.0.0.1:8000/v1/mcp/docs","allowedTools":["search_documents","fetch_document_chunk","list_document_bases"]}]'

# S3-compatible object storage for uploaded files. Local Docker uses MinIO from docker-compose.yml.
INFRA_AGENT_OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
INFRA_AGENT_OBJECT_STORAGE_SANDBOX_ENDPOINT=http://host.docker.internal:9000
INFRA_AGENT_OBJECT_STORAGE_BUCKET=infra-agents-files
INFRA_AGENT_OBJECT_STORAGE_REGION=us-east-1
INFRA_AGENT_OBJECT_STORAGE_S3_PROVIDER=Minio
INFRA_AGENT_OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
INFRA_AGENT_OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
INFRA_AGENT_OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Document indexing. V1 retrieval is semantic-only: LiteParse -> chunks -> embeddings -> pgvector.
INFRA_AGENT_DOCUMENT_PARSER=liteparse
INFRA_AGENT_DOCUMENT_CHUNK_SIZE=1200
INFRA_AGENT_DOCUMENT_CHUNK_OVERLAP=160
INFRA_AGENT_DOCUMENT_EMBEDDING_PROVIDER=openai
INFRA_AGENT_DOCUMENT_EMBEDDING_MODEL=text-embedding-3-large
INFRA_AGENT_DOCUMENT_EMBEDDING_DIMENSIONS=3072
# INFRA_AGENT_DOCUMENT_EMBEDDING_API_KEY=sk-...
# INFRA_AGENT_DOCUMENT_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Optional git identity used inside sandboxes. GitHub App runs default to the app bot identity.
# INFRA_AGENT_GIT_AUTHOR_NAME=Infra Agent
# INFRA_AGENT_GIT_AUTHOR_EMAIL=infra-agent@example.com
# INFRA_AGENT_GIT_COMMITTER_NAME=Infra Agent
# INFRA_AGENT_GIT_COMMITTER_EMAIL=infra-agent@example.com

# Actual sandbox credentials. Prefer short-lived credentials.
# When ARM/AZURE service-principal vars are present, the worker pre-authenticates normal Azure CLI
# inside the sandbox with `az login --service-principal` before the agent starts.
# ARM_CLIENT_ID=...
# ARM_CLIENT_SECRET=...
# ARM_TENANT_ID=...
# ARM_SUBSCRIPTION_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_TENANT_ID=...
# AZURE_SUBSCRIPTION_ID=...
# GH_TOKEN=...
# GITHUB_TOKEN=...

# GitHub App manifest flow.
# INFRA_AGENT_GITHUB_APP_MANIFEST_BASE_URL=https://YOUR_DOMAIN
# INFRA_AGENT_GITHUB_APP_MANIFEST_STATE_SECRET=change-me
# INFRA_AGENT_GITHUB_APP_ID=
# INFRA_AGENT_GITHUB_CLIENT_ID=
# INFRA_AGENT_GITHUB_CLIENT_SECRET=
# INFRA_AGENT_GITHUB_APP_SLUG=
# INFRA_AGENT_GITHUB_WEBHOOK_SECRET=
# INFRA_AGENT_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
