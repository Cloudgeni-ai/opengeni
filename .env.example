# Copy to .env and fill in. Never commit .env.
#
# Full stack: temporal server start-dev, alembic upgrade, worker + API with these set.

INFRA_AGENT_ENABLE_TEMPORAL_DISPATCH=true
INFRA_AGENT_OPENAI_PROVIDER=azure
INFRA_AGENT_AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
INFRA_AGENT_AZURE_OPENAI_API_KEY=your-key
# Optional with base_url v1 style: omit api version
INFRA_AGENT_OPENAI_MODEL=gpt-5.4
INFRA_AGENT_SANDBOX_BACKEND=modal

# Sandbox backend:
# - modal: hosted Modal sandbox
# - docker: local Docker container sandbox
# - none: disable sandbox dispatch
#
# Docker requires Docker Engine and the openai-agents docker extra.
# The image must contain git for repository resources to mount through GitRepo.
# INFRA_AGENT_SANDBOX_BACKEND=docker
INFRA_AGENT_DOCKER_IMAGE=infra-agents-sandbox:local
# INFRA_AGENT_DOCKER_EXPOSED_PORTS=

INFRA_AGENT_MODAL_APP_NAME=infra-agents-sandbox

# Modal: worker sets MODAL_TOKEN_ID, MODAL_TOKEN_SECRET (etc.) for the official `modal` client
# (same names Modal reads; env wins over ~/.modal.toml). Use INFRA_AGENT_ prefix with .env, or
# set MODAL_* in the shell instead. If both are omitted, use: modal token set ...
INFRA_AGENT_MODAL_TOKEN_ID=ak-...
INFRA_AGENT_MODAL_TOKEN_SECRET=as-...
# INFRA_AGENT_MODAL_PROFILE=default
# INFRA_AGENT_MODAL_CONFIG_PATH=/path/to/.modal.toml
