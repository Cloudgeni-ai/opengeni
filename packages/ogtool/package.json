{
  "name": "@opengeni/ogtool",
  "version": "0.0.0",
  "description": "Dependency-free CLI for calling the OpenGeni Toolspace MCP surface from a sandbox or custom rig.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloudgeni-ai/opengeni.git",
    "directory": "packages/ogtool"
  },
  "bin": {
    "ogtool": "./bin/ogtool.cjs"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "build": "tsup",
    "prepublishOnly": "bash ../../scripts/prepublish-guard"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
