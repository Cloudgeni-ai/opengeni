{
  "name": "@opengeni/network",
  "version": "0.1.0",
  "description": "DNS-pinned outbound HTTP transport for OpenGeni credential-bearing requests.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloudgeni-ai/opengeni.git",
    "directory": "packages/network"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bash ../../scripts/prepublish-guard"
  },
  "dependencies": {
    "undici": "^6.21.3"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
