{
  "name": "@opengeni/worker-bundle",
  "version": "0.7.8",
  "description": "OpenGeni worker entry: runOpenGeniWorker/createOpenGeniWorker(deps) + the un-bundled Temporal workflow source tree. An engine-distribution surface — its runtime closure includes engine-internal packages and the workflow bundle ships as on-disk TS source.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloudgeni-ai/opengeni.git",
    "directory": "apps/worker"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "dev:watch": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsgo --noEmit",
    "build": "tsup",
    "prepublishOnly": "bash ../../scripts/prepublish-guard"
  },
  "dependencies": {
    "@opengeni/codex": "workspace:*",
    "@opengeni/config": "workspace:*",
    "@opengeni/contracts": "workspace:*",
    "@opengeni/core": "workspace:*",
    "@opengeni/db": "workspace:*",
    "@opengeni/documents": "workspace:*",
    "@opengeni/events": "workspace:*",
    "@opengeni/observability": "workspace:*",
    "@opengeni/runtime": "workspace:*",
    "@opengeni/storage": "workspace:*",
    "@temporalio/activity": "^1.17.0",
    "@temporalio/client": "^1.17.0",
    "@temporalio/worker": "^1.17.0",
    "@temporalio/workflow": "^1.17.0"
  },
  "devDependencies": {
    "@openai/agents-core": "0.13.3",
    "@opengeni/testing": "workspace:*",
    "postgres": "^3.4.9",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
